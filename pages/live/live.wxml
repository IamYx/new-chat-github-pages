<view class="page">
  <view class="screen">
    <live-pusher
      id="livePusher"
      class="pusher"
      url="{{pushUrl}}"
      mode="RTC"
      autopush="{{false}}"
      enable-camera="{{true}}"
      enable-mic="{{true}}"
      beauty="{{beauty}}"
      muted="{{muted}}"
      orientation="vertical"
      bindstatechange="onPusherState"
      binderror="onPusherError"
    />
  </view>

  <view class="controls">
    <view class="field">
      <text class="label">推流地址</text>
      <input class="input" value="{{pushUrl}}" placeholder="rtmp:// 或 webrtc:// 推流地址" bindinput="onPushUrlInput" />
    </view>

    <view class="field">
      <text class="label">房间号</text>
      <input class="input" value="{{roomId}}" placeholder="聊天室房间号" bindinput="onRoomInput" />
    </view>

    <view class="field">
      <text class="label">聊天室地址</text>
      <input class="input" value="{{wsUrl}}" placeholder="ws://127.0.0.1:8787" bindinput="onWsInput" />
    </view>

    <view class="button-row">
      <button class="primary-btn action" wx:if="{{!pushing}}" bindtap="startPush">开始直播</button>
      <button class="danger-btn action" wx:else bindtap="stopPush">停止直播</button>
      <button class="ghost-btn small-action" bindtap="switchCamera">翻转</button>
    </view>

    <view class="button-row">
      <button class="ghost-btn action" bindtap="toggleMuted">{{muted ? '开麦' : '静音'}}</button>
      <button class="ghost-btn action" bindtap="toggleBeauty">美颜 {{beauty}}</button>
    </view>

    <text class="status">{{statusText}}</text>
  </view>

  <view class="chat">
    <view class="chat-head">
      <text class="chat-title">直播聊天</text>
      <text class="chat-state">{{chatStatus}}</text>
    </view>
    <scroll-view class="messages" scroll-y scroll-into-view="{{lastMessageId}}">
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
        class="message {{item.mine ? 'mine' : ''}}"
      >
        <view class="message-meta">{{item.userName}} · {{item.time}}</view>
        <view class="message-text">{{item.text}}</view>
      </view>
    </scroll-view>
    <view class="chat-bar">
      <input class="chat-input" value="{{draft}}" placeholder="输入聊天内容" confirm-type="send" bindinput="onDraftInput" bindconfirm="sendMessage" />
      <button class="send-btn" bindtap="sendMessage">发送</button>
    </view>
  </view>
</view>
