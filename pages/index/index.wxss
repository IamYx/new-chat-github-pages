.home {
  padding-top: 72rpx;
}

.hero {
  margin-bottom: 44rpx;
}

.title {
  display: block;
  color: #101828;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 68rpx;
}

.subtitle {
  display: block;
  width: 88%;
  margin-top: 14rpx;
  color: #667085;
  font-size: 28rpx;
  line-height: 42rpx;
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.entry {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  height: 188rpx;
  box-sizing: border-box;
  padding: 32rpx;
  color: #fff;
  text-align: left;
  border-radius: 8px;
}

.live-entry {
  background: #176b87;
}

.play-entry {
  background: #344054;
}

.entry-title {
  font-size: 34rpx;
  font-weight: 800;
  line-height: 46rpx;
}

.entry-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 38rpx;
  opacity: 0.88;
}
