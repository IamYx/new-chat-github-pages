page {
  min-height: 100%;
  background: #f5f7fb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

button {
  border-radius: 6px;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
}

.screen {
  background: #111827;
  overflow: hidden;
  border-radius: 8px;
}

.field {
  margin-bottom: 18rpx;
}

.label {
  display: block;
  margin-bottom: 8rpx;
  color: #475467;
  font-size: 24rpx;
}

.input {
  height: 76rpx;
  box-sizing: border-box;
  padding: 0 22rpx;
  border: 1px solid #d0d5dd;
  border-radius: 6px;
  background: #fff;
  color: #101828;
  font-size: 26rpx;
}

.primary-btn {
  height: 80rpx;
  background: #176b87;
  color: #fff;
  font-size: 28rpx;
  line-height: 80rpx;
}

.ghost-btn {
  height: 72rpx;
  border: 1px solid #d0d5dd;
  background: #fff;
  color: #344054;
  font-size: 26rpx;
  line-height: 72rpx;
}

.danger-btn {
  height: 72rpx;
  background: #b42318;
  color: #fff;
  font-size: 26rpx;
  line-height: 72rpx;
}

.status {
  min-height: 38rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 38rpx;
}

.chat {
  margin-top: 28rpx;
  background: #fff;
  border: 1px solid #e4e7ec;
  border-radius: 8px;
  overflow: hidden;
}

.chat-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 22rpx;
  border-bottom: 1px solid #eaecf0;
}

.chat-title {
  font-size: 28rpx;
  font-weight: 700;
}

.chat-state {
  color: #667085;
  font-size: 22rpx;
}

.messages {
  height: 360rpx;
  padding: 18rpx 22rpx;
  box-sizing: border-box;
}

.message {
  margin-bottom: 16rpx;
}

.message-meta {
  color: #667085;
  font-size: 22rpx;
}

.message-text {
  display: inline-block;
  max-width: 88%;
  margin-top: 4rpx;
  padding: 12rpx 16rpx;
  border-radius: 6px;
  background: #f2f4f7;
  color: #101828;
  font-size: 26rpx;
  line-height: 38rpx;
  word-break: break-all;
}

.message.mine {
  text-align: right;
}

.message.mine .message-text {
  background: #d7f3ef;
}

.chat-bar {
  display: flex;
  gap: 12rpx;
  padding: 14rpx;
  border-top: 1px solid #eaecf0;
}

.chat-input {
  flex: 1;
  height: 68rpx;
  box-sizing: border-box;
  padding: 0 18rpx;
  border: 1px solid #d0d5dd;
  border-radius: 6px;
  background: #fff;
  font-size: 26rpx;
}

.send-btn {
  width: 132rpx;
  height: 68rpx;
  background: #176b87;
  color: #fff;
  font-size: 26rpx;
  line-height: 68rpx;
}
